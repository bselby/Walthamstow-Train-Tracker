# Credentials issued by raildata.org.uk for the Combined Train Describer feed
# (Kafka via Confluent Cloud).
KAFKA_USERNAME=your-confluent-api-key
KAFKA_PASSWORD=your-confluent-api-secret
# Override only if raildata.org.uk re-issues a different consumer group ID.
# KAFKA_GROUP_ID=SC-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

PORT=8080
ALLOWED_ORIGIN=http://localhost:5173
